mod switch_example;

lib "stdio" = io;

ext fn main(void): i32 {
    stack i32 x = 3;

    switch x {
        case 1: {
            io.printf("one\n");
        }
        case 2, 3: {
            io.printf("two or three\n");
        }
        case 4: {
            io.printf("four\n");
        }
        default: {
            io.printf("something else\n");
        }
    }

    ret 0;
}
