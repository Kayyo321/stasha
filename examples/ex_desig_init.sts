mod desig_init_example;

lib "stdio" = io;

type Point: struct {
    stack:
        ext i32 x;
        ext i32 y;
        ext i32 z;
};

ext fn main(void): i32 {
    // designated initializer — set fields by name
    stack Point p = Point { .x = 10, .y = 20, .z = 30 };
    io.printf("point: (%d, %d, %d)\n", p.x, p.y, p.z);

    // only some fields — others default to zero
    stack Point q = Point { .y = 99 };
    io.printf("point q: (%d, %d, %d)\n", q.x, q.y, q.z);

    ret 0;
}
