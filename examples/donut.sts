mod ex;

lib "stdio"  = cio;
lib "math"   = cmath;
lib "string" = cstring;
lib "unistd" = custd;

fn main(void): i16 {
    f64 [A, B] = 0, 0;
    f64 i;
    f64 j;
    i32 k;
    f64 z[1760];
    i8 b[1760];

    // lookup table for shading characters
    stack i8 *r chars = '.,-~:;=!*#$@';

    inf {
        for (k = 0; k < 1760; ++k) {
            z[k] = 0;
            b[k] = ` `;
        }
        for (j = 0; j < 6.28; j += 0.07) {
            for (i = 0; i < 6.28; i += 0.02) {
                f64 c = cmath.sin(i);
                f64 d = cmath.cos(j);
                f64 e = cmath.sin(A);
                f64 f = cmath.sin(j);
                f64 g = cmath.cos(A);
                f64 h = d + 2;
                f64 D = 1 / (c * h * e + f * g + 5);
                f64 l = cmath.cos(i);
                f64 m = cmath.cos(B);
                f64 n = cmath.sin(B);
                f64 t = c * h * g - f * e;
                i32 x = 40 + 30 * D * (l * h * m - t * n);
                i32 y = 12 + 15 * D * (l * h * n + t * m);
                i32 o = x + 80 * y;
                i32 N = 8 * ((f * e - c * d * g) * m - c * d * e - f * g - l * d * n);
                if (22 > y && y > 0 && x > 0 && 80 > x && D > z[o]) {
                    z[o] = D;
                    b[o] = chars[N > 0 ? N : 0];
                }
            }
        }

        cio.printf('\x1b[H');
        for (k = 0; k < 1760; ++k) {
            cio.printf('%c', b[k]);
            if (k % 80 == 79) {
                cio.printf('\n');
            }
        }
        A += 0.04;
        B += 0.02;

        custd.usleep(30000);
    }
    ret 0;
}
