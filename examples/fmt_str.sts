mod fmt_str;

fn ret_it(stack i32 it): heap i8 *rw {
    ret heap @'it = {it}';
}

fn main(void): i32 {
    stack i32 a = 1;
    stack i32 b = 2;
    stack i32 c = 3;

    print.(@'{a} + {b} * {c} = {a + b * c}\n');

    heap i8 *rw s = ret_it(123);
    defer rem.(s);
    print.('{}\n', s);

    ret 0;
}
