mod ex_preproc;

@comptime fn say_hello! {
    () => {
        print.('hello\n');
    };
}

@comptime fn repeat! {
    (@msg, @count) => {
        for (i32 i = 0; i < @count; ++i) {
            print.(@msg);
        }
    };
}

@comptime let integer! = i32;

fn main(void): i32 {
    say_hello.!();

    const integer.! i = 10;
    // same as const i32 i = 10;
    print.('i = {}\n', i);

    repeat.!('repeated\n', 3);

    ret 0;
}