mod restrict_example;

lib "stdio" = io;

// restrict pointer hint — tells the compiler pointers don't alias
// enables better auto-vectorization (like C's restrict qualifier)
ext fn add_values(stack restrict i32 *rw dst, stack restrict i32 *r src): void {
    dst[0] = dst[0] + src[0];
}

ext fn main(void): i32 {
    stack i32 a = 10;
    stack i32 b = 20;

    add_values(&a, &b);

    io.printf("result: %d\n", a);

    ret 0;
}
