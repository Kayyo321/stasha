mod weak_hidden_example;

lib "stdio" = io;

// @weak — can be overridden by another definition at link time
@weak
ext fn default_handler(void): void {
    io.printf("default handler\n");
}

// @hidden — not exported from shared library
@hidden
int fn internal_helper(void): void {
    io.printf("internal helper\n");
}

ext fn main(void): i32 {
    default_handler();
    internal_helper();
    ret 0;
}
