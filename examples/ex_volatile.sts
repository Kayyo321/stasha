mod volatile_example;

lib "stdio" = io;

ext fn main(void): i32 {
    // volatile prevents the compiler from optimizing away loads/stores
    // essential for memory-mapped I/O and hardware registers
    stack volatile i32 flag = 0;

    flag = 1;
    io.printf("flag = %d\n", flag);

    flag = 0;
    io.printf("flag = %d\n", flag);

    ret 0;
}
