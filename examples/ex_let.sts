mod ex_let;

lib "stdio" = io;

fn divide(stack f32 x, y): [f32, error] {
    if (y == 0) {
        return 0.0, error.('Divide by zero!');
    }

    return x / y, nil;
}

fn main(void): i16 {
    stack let [res, err] = divide(20, 10);
    if (err == nil) {
        io.printf('20 / 10 is %g\n', res);
    }

    stack let [_, err1] = divide(20, 0);
    if (err1 != nil) {
        io.printf('20 / 0 is ERROR!\n');
    }

    ret 0;
}