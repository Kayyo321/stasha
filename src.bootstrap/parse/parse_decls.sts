mod parse.parse_decls;

imp lex.token;

ext fn is_decl_start(token.token_kind_t kind): bool {
    switch kind {
        case token.token_kind_t.TokFn,
             token.token_kind_t.TokType,
             token.token_kind_t.TokLib,
             token.token_kind_t.TokLibImp,
             token.token_kind_t.TokCHeader,
             token.token_kind_t.TokTest: {
            ret true;
        }
        default: ret false;
    }
}
