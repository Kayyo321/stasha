{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Stasha",
  "scopeName": "source.stasha",
  "fileTypes": ["sts"],
  "patterns": [
    { "include": "#comment-line" },
    { "include": "#comment-block" },
    { "include": "#string-comptime" },
    { "include": "#string-dollar" },
    { "include": "#char-literal" },
    { "include": "#string-single" },
    { "include": "#string-double" },
    { "include": "#number" },
    { "include": "#comptime-generic" },
    { "include": "#attributes" },
    { "include": "#variadic" },
    { "include": "#pointer-perm" },
    { "include": "#asm-block" },
    { "include": "#unsafe-block" },
    { "include": "#test-block" },
    { "include": "#module-path" },
    { "include": "#dot-compound-init" },
    { "include": "#generic-instantiation" },
    { "include": "#dot-dispatch" },
    { "include": "#type-member-access" },
    { "include": "#builtin-calls" },
    { "include": "#keyword-control" },
    { "include": "#keyword-declaration" },
    { "include": "#storage-qualifier" },
    { "include": "#keyword-async" },
    { "include": "#keyword-misc" },
    { "include": "#type-primitive" },
    { "include": "#type-name" },
    { "include": "#operator-special" },
    { "include": "#operator" },
    { "include": "#method-call" },
    { "include": "#function-call" },
    { "include": "#this-keyword" },
    { "include": "#identifier" }
  ],
  "repository": {

    "comment-line": {
      "name": "comment.line.double-slash.stasha",
      "match": "//.*$"
    },

    "comment-block": {
      "name": "comment.block.stasha",
      "begin": "/\\*",
      "end": "\\*/",
      "patterns": [{ "include": "#comment-block" }]
    },

    "string-comptime": {
      "name": "string.quoted.comptime.stasha",
      "begin": "@\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.stasha" } },
      "end": "\"",
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.stasha" } },
      "patterns": [
        { "name": "constant.character.escape.stasha", "match": "\\\\." },
        {
          "name": "meta.interpolation.comptime.stasha",
          "begin": "\\{",
          "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.stasha" } },
          "end": "\\}",
          "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.stasha" } },
          "patterns": [{ "include": "$self" }]
        }
      ]
    },

    "string-dollar": {
      "name": "string.quoted.dollar.stasha",
      "begin": "\\$\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.stasha" } },
      "end": "\"",
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.stasha" } },
      "patterns": [
        { "name": "constant.character.escape.stasha", "match": "\\\\." },
        {
          "name": "meta.interpolation.stasha",
          "begin": "\\{",
          "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.stasha" } },
          "end": "\\}",
          "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.stasha" } },
          "patterns": [{ "include": "$self" }]
        }
      ]
    },

    "char-literal": {
      "name": "constant.character.literal.stasha",
      "match": "'(?:\\\\.|[^'\\\\])'"
    },

    "string-single": {
      "name": "string.quoted.single.stasha",
      "begin": "'(?=[^'\\\\]*(\\\\.[^'\\\\]*)*')",
      "end": "'",
      "patterns": [
        { "name": "constant.character.escape.stasha", "match": "\\\\[\\\\nrtbf0']" },
        {
          "name": "meta.format-spec.stasha",
          "match": "(\\{)([^}:]*)?(?:(:)([^}]*))?(\\.?\\})",
          "captures": {
            "1": { "name": "punctuation.section.interpolation.begin.stasha" },
            "2": { "name": "variable.other.stasha" },
            "3": { "name": "punctuation.separator.stasha" },
            "4": { "name": "constant.other.format-spec.stasha" },
            "5": { "name": "punctuation.section.interpolation.end.stasha" }
          }
        }
      ]
    },

    "string-double": {
      "name": "string.quoted.double.stasha",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.stasha", "match": "\\\\[\\\\\"nrtbf0]" },
        {
          "name": "meta.format-spec.stasha",
          "match": "(\\{)([^}:]*)?(?:(:)([^}]*))?(\\.?\\})",
          "captures": {
            "1": { "name": "punctuation.section.interpolation.begin.stasha" },
            "2": { "name": "variable.other.stasha" },
            "3": { "name": "punctuation.separator.stasha" },
            "4": { "name": "constant.other.format-spec.stasha" },
            "5": { "name": "punctuation.section.interpolation.end.stasha" }
          }
        }
      ]
    },

    "number": {
      "patterns": [
        { "name": "constant.numeric.hex.stasha",     "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b" },
        { "name": "constant.numeric.binary.stasha",  "match": "\\b0[bB][01][01_]*\\b" },
        { "name": "constant.numeric.float.stasha",   "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9]+)?\\b" },
        { "name": "constant.numeric.integer.stasha", "match": "\\b[0-9][0-9_]*\\b" }
      ]
    },

    "comptime-generic": {
      "name": "meta.generic.stasha",
      "match": "@comptime\\[([A-Za-z_][A-Za-z0-9_,\\s]*)\\]",
      "captures": {
        "0": { "name": "entity.other.attribute-name.stasha" },
        "1": { "name": "entity.name.type.parameter.stasha" }
      }
    },

    "attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.stasha",
          "match": "@(?:comptime|packed|align|c_layout|weak|hidden|restrict|frees|foreach)\\b"
        },
        {
          "name": "entity.other.attribute-name.stasha",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.other.attribute-name.stasha",
          "match": "#(?:if|include)\\b"
        }
      ]
    },

    "variadic": {
      "name": "keyword.operator.variadic.stasha",
      "match": "\\.\\.\\."
    },

    "pointer-perm": {
      "name": "storage.modifier.pointer.stasha",
      "match": "\\*(?:rw\\+|r\\+|w\\+|rw|r|w|\\+)"
    },

    "asm-block": {
      "name": "meta.block.asm.stasha",
      "begin": "\\basm\\s*\\{",
      "beginCaptures": { "0": { "name": "keyword.other.stasha" } },
      "end": "\\}",
      "patterns": [
        { "include": "#comment-line" },
        { "include": "#comment-block" },
        { "include": "#string-double" },
        { "include": "#string-single" },
        { "name": "string.unquoted.asm.stasha", "match": "[^{}]+" }
      ]
    },

    "unsafe-block": {
      "name": "meta.block.unsafe.stasha",
      "begin": "\\bunsafe\\s*\\{",
      "beginCaptures": { "0": { "name": "keyword.declaration.stasha" } },
      "end": "\\}",
      "patterns": [{ "include": "$self" }]
    },

    "test-block": {
      "name": "meta.block.test.stasha",
      "match": "\\b(test)\\s+('[^']*')",
      "captures": {
        "1": { "name": "keyword.declaration.stasha" },
        "2": { "name": "entity.name.function.test.stasha" }
      }
    },

    "module-path": {
      "patterns": [
        {
          "match": "\\b(mod|imp)\\s+([a-z_][a-zA-Z0-9_]*(?:\\.[a-z_][a-zA-Z0-9_]*)*)",
          "captures": {
            "1": { "name": "keyword.declaration.stasha" },
            "2": { "name": "entity.name.namespace.stasha" }
          }
        },
        {
          "match": "\\b(libimp)\\s+(\"[^\"]*\")(?:\\s+(from)(?:\\s+(std|\"[^\"]*\"))?)?",
          "captures": {
            "1": { "name": "keyword.declaration.stasha" },
            "2": { "name": "string.quoted.double.stasha" },
            "3": { "name": "keyword.other.stasha" },
            "4": { "name": "entity.name.namespace.stasha" }
          }
        }
      ]
    },

    "dot-compound-init": {
      "name": "meta.compound-init.stasha",
      "begin": "\\.\\{",
      "beginCaptures": { "0": { "name": "punctuation.section.compound-init.begin.stasha" } },
      "end": "\\}",
      "endCaptures": { "0": { "name": "punctuation.section.compound-init.end.stasha" } },
      "patterns": [{ "include": "$self" }]
    },

    "generic-instantiation": {
      "name": "meta.generic-instantiation.stasha",
      "match": "\\.\\[([A-Za-z_][A-Za-z0-9_,\\s]*)\\]",
      "captures": {
        "0": { "name": "punctuation.section.generic.stasha" },
        "1": { "name": "entity.name.type.parameter.stasha" }
      }
    },

    "dot-dispatch": {
      "name": "punctuation.accessor.dot-dispatch.stasha",
      "match": "\\.(?=[\\(\\[\\{])"
    },

    "type-member-access": {
      "match": "\\b([A-Z][A-Za-z0-9_]*)(\\.)([A-Z][A-Za-z0-9_]*|[a-z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "entity.name.type.stasha" },
        "2": { "name": "punctuation.accessor.member.stasha" },
        "3": { "name": "entity.name.function.static.stasha" }
      }
    },

    "builtin-calls": {
      "patterns": [
        {
          "name": "support.function.builtin.stasha",
          "match": "\\b(?:print|rem|new|mov|sizeof|expect|expect_eq|expect_neq|test_fail|lam|make|append|copy|len|cap|comptime_assert)\\.(?=\\(|\\.\\(|\\[)"
        },
        {
          "name": "support.function.builtin.stasha",
          "match": "\\b(?:future|stream|await|async|thread)\\."
        }
      ]
    },

    "keyword-control": {
      "name": "keyword.control.stasha",
      "match": "\\b(?:if|else|for|while|do|inf|match|switch|case|default|break|continue|ret|defer|yield|with|foreach|in)\\b"
    },

    "keyword-declaration": {
      "name": "keyword.declaration.stasha",
      "match": "\\b(?:fn|type|mod|imp|lib|libimp|ext|int|test|struct|enum|union|interface|let|zone|unsafe|unchecked)\\b"
    },

    "storage-qualifier": {
      "name": "storage.type.stasha",
      "match": "\\b(?:stack|heap|atomic|const|final|volatile|tls|restrict)\\b"
    },

    "keyword-async": {
      "name": "keyword.other.async.stasha",
      "match": "\\b(?:async|await|thread|future|stream|yield)\\b"
    },

    "keyword-misc": {
      "patterns": [
        { "name": "keyword.other.stasha",          "match": "\\b(?:from|std|asm|watch|send|quit|any|macro)\\b" },
        { "name": "constant.language.boolean.stasha", "match": "\\b(?:true|false)\\b" },
        { "name": "constant.language.null.stasha",    "match": "\\bnil\\b" }
      ]
    },

    "type-primitive": {
      "name": "support.type.primitive.stasha",
      "match": "\\b(?:i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|void|error|future|stream)\\b"
    },

    "type-name": {
      "name": "entity.name.type.stasha",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },

    "operator-special": {
      "patterns": [
        { "name": "keyword.operator.wrapping.stasha",   "match": "[+\\-\\*]%" },
        { "name": "keyword.operator.trapping.stasha",   "match": "[+\\-\\*]!" },
        { "name": "keyword.operator.pipeline.stasha",   "match": "\\|>" },
        { "name": "keyword.operator.range.stasha",      "match": "\\.\\.(=?)" },
        { "name": "keyword.operator.range-step.stasha", "match": "(?<=\\.\\.=?\\d+):" },
        { "name": "keyword.operator.fat-arrow.stasha",  "match": "=>" },
        { "name": "keyword.operator.addr.stasha",       "match": "&(?=[a-zA-Z_])" }
      ]
    },

    "operator": {
      "name": "keyword.operator.stasha",
      "match": "\\+\\+|--|[+\\-*/%]|[&|^~]|<<|>>|&&|\\|\\||!|[<>]=?|==|!=|\\.==|[+\\-*/%&|^<>]=|="
    },

    "method-call": {
      "match": "(?<=[a-zA-Z0-9_\\]\\)])(\\.)([a-z_][a-zA-Z0-9_]*)(?=\\.?\\()",
      "captures": {
        "1": { "name": "punctuation.accessor.member.stasha" },
        "2": { "name": "entity.name.function.member.stasha" }
      }
    },

    "function-call": {
      "name": "entity.name.function.stasha",
      "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\.?\\()"
    },

    "this-keyword": {
      "name": "variable.language.this.stasha",
      "match": "\\bthis\\b"
    },

    "identifier": {
      "name": "variable.other.stasha",
      "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
    }
  }
}
