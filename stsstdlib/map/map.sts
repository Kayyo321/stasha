mod map;

// Open-addressing hash map with linear probing — generic via @comptime[K, V].
// Keys are hashed with the universal hash.() built-in; equality is checked
// byte-by-byte against keys stored in the bucket.
// Each bucket layout: [state: u8][key: sizeof.(K) bytes][val: sizeof.(V) bytes]
//   state 0 = empty, 1 = occupied, 2 = tombstone

const u8 MAP_EMPTY     = 0;
const u8 MAP_OCCUPIED  = 1;
const u8 MAP_TOMBSTONE = 2;

ext type map_t: @comptime[K, V] struct {
heap:
    int u8 *rw+ buckets;

stack:
    int u32 count, cap;

    // Byte size of one bucket slot.
    int fn slot_size(void): u32 {
        ret 1 + sizeof.(K) + sizeof.(V);
    }

    // Pointer to the start of bucket i.
    int fn bucket_ptr(stack u32 i): u8 *rw+ {
        ret map_t.(buckets) + (i * map_t.(slot_size)());
    }

    // Copy n bytes from src to dst.
    int fn copy_bytes(stack u8 *w dst, stack u8 *r src, stack u32 n): void {
        for (u32 i = 0; i < n; i++) { dst[i] = src[i]; }
    }

    // Grow and rehash when load factor exceeds 0.7.
    int fn maybe_grow(void): void {
        // count / cap > 0.7  →  count * 10 > cap * 7
        if (map_t.(count) * 10 <= map_t.(cap) * 7) { ret; }

        final u32 old_cap     = map_t.(cap);
        heap u8 *rw+ old_bkts = map_t.(buckets);
        final u32 ss          = map_t.(slot_size)();
        final u32 new_cap     = old_cap * 2;

        map_t.(buckets) = new.(new_cap * ss);
        for (u32 i = 0; i < new_cap * ss; i++) { map_t.(buckets)[i] = 0; }
        map_t.(cap)   = new_cap;
        map_t.(count) = 0;

        for (u32 i = 0; i < old_cap; i++) {
            heap u8 *rw+ slot = old_bkts + (i * ss);
            if (slot[0] == MAP_OCCUPIED) {
                stack u8 *r rkey = slot + 1;
                stack u8 *r rval = slot + 1 + sizeof.(K);
                stack K rk = ((K *r)rkey)[0];
                stack u32 idx  = (u32)(hash.(rk) % (u64)map_t.(cap));
                stack u32 tomb = map_t.(cap);
                inf {
                    u8 *rw dst = map_t.(bucket_ptr)(idx);
                    if (dst[0] == MAP_EMPTY) {
                        final u32 w = (tomb < map_t.(cap)) ? tomb : idx;
                        u8 *rw+ wdst = map_t.(bucket_ptr)(w);
                        wdst[0] = MAP_OCCUPIED;
                        map_t.(copy_bytes)(wdst + 1, rkey, sizeof.(K));
                        map_t.(copy_bytes)(wdst + 1 + sizeof.(K), rval, sizeof.(V));
                        map_t.(count)++;
                        break;
                    }
                    if (dst[0] == MAP_TOMBSTONE) {
                        if (tomb == map_t.(cap)) { tomb = idx; }
                    }
                    idx = (idx + 1) % map_t.(cap);
                }
            }
        }
        rem.(old_bkts);
    }

    // Insert or update the value for key.
    ext fn insert(stack K key, stack V val): void {
        map_t.(maybe_grow)();
        stack u32 idx  = (u32)(hash.(key) % (u64)map_t.(cap));
        stack u32 tomb = map_t.(cap);

        inf {
            u8 *rw+ slot = map_t.(bucket_ptr)(idx);
            if (slot[0] == MAP_EMPTY) {
                final u32 write = (tomb < map_t.(cap)) ? tomb : idx;
                u8 *rw+ dst = map_t.(bucket_ptr)(write);
                dst[0] = MAP_OCCUPIED;
                map_t.(copy_bytes)(dst + 1, (u8 *r)&key, sizeof.(K));
                map_t.(copy_bytes)(dst + 1 + sizeof.(K), (u8 *r)&val, sizeof.(V));
                map_t.(count)++;
                ret;
            }
            if (slot[0] == MAP_TOMBSTONE) {
                if (tomb == map_t.(cap)) { tomb = idx; }
            } else {
                if (equ.(((K *r)(slot + 1))[0], key)) {
                    map_t.(copy_bytes)(slot + 1 + sizeof.(K), (u8 *r)&val, sizeof.(V));
                    ret;
                }
            }
            idx = (idx + 1) % map_t.(cap);
        }
    }

    // Get a read-only pointer to the value for key, or nil if not found.
    ext fn get_or_nil(stack K key): V *r {
        stack u32 idx    = (u32)(hash.(key) % (u64)map_t.(cap));
        stack u32 probed = 0;
        while (probed < map_t.(cap)) {
            u8 *rw+ slot = map_t.(bucket_ptr)(idx);
            if (slot[0] == MAP_EMPTY) { ret nil; }
            if (slot[0] == MAP_OCCUPIED && equ.(((K *r)(slot + 1))[0], key)) {
                ret (V *r)(slot + 1 + sizeof.(K));
            }
            idx = (idx + 1) % map_t.(cap);
            probed++;
        }
        ret nil;
    }

    // Get a read-only pointer to the value for key, or error if not found.
    ext fn get(stack K key): [V *r, error] {
        stack u32 idx    = (u32)(hash.(key) % (u64)map_t.(cap));
        stack u32 probed = 0;
        while (probed < map_t.(cap)) {
            u8 *rw+ slot = map_t.(bucket_ptr)(idx);
            if (slot[0] == MAP_EMPTY) {
                ret nil, error.('key not found');
            }
            if (slot[0] == MAP_OCCUPIED && equ.(((K *r)(slot + 1))[0], key)) {
                ret (V *r)(slot + 1 + sizeof.(K)), nil;
            }
            idx = (idx + 1) % map_t.(cap);
            probed++;
        }
        ret nil, error.('key not found');
    }

    // Remove key. No-op if not present.
    ext fn remove(stack K key): void {
        stack u32 idx    = (u32)(hash.(key) % (u64)map_t.(cap));
        stack u32 probed = 0;
        while (probed < map_t.(cap)) {
            u8 *rw+ slot = map_t.(bucket_ptr)(idx);
            if (slot[0] == MAP_EMPTY) { ret; }
            if (slot[0] == MAP_OCCUPIED && equ.(((K *r)(slot + 1))[0], key)) {
                slot[0] = MAP_TOMBSTONE;
                map_t.(count)--;
                ret;
            }
            idx = (idx + 1) % map_t.(cap);
            probed++;
        }
    }

    // True if key is present.
    ext fn contains(stack K key): bool {
        stack u32 idx    = (u32)(hash.(key) % (u64)map_t.(cap));
        stack u32 probed = 0;
        while (probed < map_t.(cap)) {
            u8 *rw+ slot = map_t.(bucket_ptr)(idx);
            if (slot[0] == MAP_EMPTY) { ret false; }
            if (slot[0] == MAP_OCCUPIED && equ.(((K *r)(slot + 1))[0], key)) {
                ret true;
            }
            idx = (idx + 1) % map_t.(cap);
            probed++;
        }
        ret false;
    }

    ext fn count(void): u32 {
        ret map_t.(count);
    }

    ext fn is_empty(void): bool {
        ret map_t.(count) == 0;
    }
}

// Initial capacity 16 gives decent breathing room before the first rehash.
ext fn @comptime[K, V] map_t.new(void): map_t.[K, V] {
    final u32 init_cap = 16;
    final u32 ss = 1 + sizeof.(K) + sizeof.(V);
    heap u8 *rw bkts = new.(init_cap * ss);
    for (u32 i = 0; i < init_cap * ss; i++) { bkts[i] = 0; }
    ret map_t.[K, V] {
        .buckets = bkts,
        .count   = 0,
        .cap     = init_cap,
    };
}

ext fn map_t.rem(void): void {
    if (map_t.(buckets) != nil) {
        rem.(map_t.(buckets));
    }
    map_t.(buckets) = nil;
    map_t.(count)   = 0;
    map_t.(cap)     = 0;
}

test 'map new is empty' {
    stack map_t.[i32, i32] m = map_t.[i32, i32].new();
    expect.(m.is_empty());
    expect_eq.(m.count(), 0);
}

test 'map insert and contains' {
    stack map_t.[i32, i32] m = map_t.[i32, i32].new();
    m.insert(42, 100);
    expect.(m.contains(42));
    expect_eq.(m.count(), 1);
}

test 'map get_or_nil found' {
    stack map_t.[i32, i32] m = map_t.[i32, i32].new();
    m.insert(7, 99);
    stack i32 *r ptr = m.get_or_nil(7);
    expect.(ptr != nil);
    expect_eq.(ptr[0], 99);
}

test 'map get_or_nil missing returns nil' {
    stack map_t.[i32, i32] m = map_t.[i32, i32].new();
    stack i32 *r ptr = m.get_or_nil(5);
    expect.(ptr == nil);
}

test 'map insert updates existing key' {
    stack map_t.[i32, i32] m = map_t.[i32, i32].new();
    m.insert(1, 10);
    m.insert(1, 20);
    expect_eq.(m.count(), 1);
    stack i32 *r ptr = m.get_or_nil(1);
    expect.(ptr != nil);
    expect_eq.(ptr[0], 20);
}

test 'map remove' {
    stack map_t.[i32, i32] m = map_t.[i32, i32].new();
    m.insert(3, 30);
    m.remove(3);
    expect.(!m.contains(3));
    expect_eq.(m.count(), 0);
}

test 'map count simple' {
    stack map_t.[i32, i32] m = map_t.[i32, i32].new();
    m.insert(42, 100);
    expect_eq.(m.count(), 1);
}

test 'map multiple entries' {
    stack map_t.[i32, i32] m = map_t.[i32, i32].new();
    m.insert(42, 100);
    expect.(m.contains(42));
    expect_eq.(m.count(), 1);
}
