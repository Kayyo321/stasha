{
  "name": "Stasha",
  "scopeName": "source.stasha",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#chars"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#dotForms"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functionDecl"
    },
    {
      "include": "#typeDecl"
    },
    {
      "include": "#moduleDecl"
    },
    {
      "include": "#libraryAlias"
    },
    {
      "include": "#methodCall"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.stasha",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.stasha",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.stasha",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.stasha",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.stasha",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "chars": {
      "patterns": [
        {
          "name": "constant.character.stasha",
          "match": "`(?:\\\\.|[^`])`"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "storage.modifier.annotation.stasha",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "dotForms": {
      "patterns": [
        {
          "name": "meta.dot-call.stasha",
          "match": "\\.\\("
        },
        {
          "name": "meta.dot-generic.stasha",
          "match": "\\.\\["
        },
        {
          "name": "meta.dot-init.stasha",
          "match": "\\.\\{"
        },
        {
          "name": "punctuation.accessor.dot.stasha",
          "match": "\\.(?=[A-Za-z_])"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.stasha",
          "match": "\\b(?:if|else|for|while|do|inf|match|switch|case|default|break|continue|ret|defer|with|comptime_if|comptime_assert)\\b"
        },
        {
          "name": "keyword.declaration.stasha",
          "match": "\\b(?:mod|imp|lib|libimp|from|fn|type|struct|enum|union|interface|let|macro|new|sizeof|thread|future|test|expect|expect_eq|expect_neq|test_fail|mov|rem|asm|print)\\b"
        },
        {
          "name": "storage.modifier.stasha",
          "match": "\\b(?:int|ext|stack|heap|atomic|const|final|volatile|tls|restrict|std)\\b"
        },
        {
          "name": "constant.language.stasha",
          "match": "\\b(?:true|false|nil|void|error|this|any)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.stasha",
          "match": "\\b(?:i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|void|error)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.stasha",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "functionDecl": {
      "patterns": [
        {
          "name": "entity.name.function.stasha",
          "match": "\\bfn\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.function.stasha"
            }
          }
        }
      ]
    },
    "typeDecl": {
      "patterns": [
        {
          "name": "entity.name.type.stasha",
          "match": "\\btype\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.type.stasha"
            }
          }
        }
      ]
    },
    "moduleDecl": {
      "patterns": [
        {
          "name": "entity.name.namespace.stasha",
          "match": "\\bmod\\s+([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": {
              "name": "entity.name.namespace.stasha"
            }
          }
        },
        {
          "name": "entity.name.namespace.stasha",
          "match": "\\bimp\\s+([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": {
              "name": "entity.name.namespace.stasha"
            }
          }
        }
      ]
    },
    "libraryAlias": {
      "patterns": [
        {
          "name": "support.constant.library.stasha",
          "match": "\\b(?:lib|libimp)\\s+(\"[^\"]+\"|'[^']+')",
          "captures": {
            "1": {
              "name": "support.constant.library.stasha"
            }
          }
        }
      ]
    },
    "methodCall": {
      "patterns": [
        {
          "name": "entity.name.function.member.stasha",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        },
        {
          "name": "variable.other.property.stasha",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*(?!\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.stasha",
          "match": "\\+\\+|--|\\+%|-\\%|\\*%|\\+!|-!|\\*!|==|!=|<=|>=|<<=|>>=|&&|\\|\\||=>|\\.\\.\\.|\\.\\.=|\\.\\.|[=+\\-*/%<>!&|^~?:]"
        }
      ]
    }
  }
}
