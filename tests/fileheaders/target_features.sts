mod target_features;

// Definition-local codegen tuning.
// Unlike a normal attribute on a struct, this changes how one function is
// emitted for a target or CPU feature set.

@[[target: "x86_64", features: "+sse4.2,+popcnt"]]
fn hash_sse(str text): u32 {
    ret 0;
}

@[[target: "aarch64", features: "+neon"]]
fn hash_neon(str text): u32 {
    ret 0;
}

@[[if: target.arch == "x86_64"]]
fn hash(str text): u32 => hash_sse(text);

@[[if: target.arch == "aarch64"]]
fn hash(str text): u32 => hash_neon(text);
