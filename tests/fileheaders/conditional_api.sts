mod conditional_api;

// Compile or reject declarations depending on target properties.
// This is broader than @comptime[T] because it is about declaration presence,
// symbol emission, and diagnostics.

@[[require: os == "linux"]]
ext fn epoll_create1(i32 flags): i32;

@[[require: os == "windows"]]
ext fn CreateEventA(void *attrs, i32 manual_reset, i32 initial_state, i8 *name): void *;

@[[if: pointer_width == 64]]
type Handle: u64;

@[[if: pointer_width == 32]]
type Handle: u32;
