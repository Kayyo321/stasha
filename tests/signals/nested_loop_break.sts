mod nested_loop_break;

type sig_t: struct {
    i32 code;
}

fn main(void): i32 {
    watch.(sig_t s) => {
        print.('enter:{}\n', s.code);
        for (stack i32 i = 0; i < 3; i++) {
            if (i == 1) { break; }
            print.('i={}\n', i);
        }
        print.('after\n');
    }
    send.(sig_t{.code = 1});
    send.(sig_t{.code = 2});
    ret 0;
}
