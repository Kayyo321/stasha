mod row13_callback_to_c;

cheader "support/callbacks.h" search "tests/cinterop";

// Stasha free fn → C function pointer parameter.
// cb_find takes int32_t (*pred)(int32_t); we pass &is_even.

ext fn is_even(i32 v): i32 {
    ret v % 2 == 0 ? 1 : 0;
}

fn main(void): i32 {
    stack i32 arr[5] = .{1, 3, 5, 4, 7};
    i32 idx = cb_find(&arr[0], 5, &is_even);
    if idx != 3 { print.("FAIL idx={}\n", idx); ret 1; }
    print.("13_callback_to_c: ok\n");
    ret 0;
}
