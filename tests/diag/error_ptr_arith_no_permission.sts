// Diagnostic test: pointer arithmetic without '+' permission
// Expected: "pointer arithmetic not permitted on 'p'" with help message
mod diag_ptr_arith;

int fn main(void): i32 {
    stack i32 x = 42;
    // *r pointer: read-only, no arithmetic permitted
    stack i32 *r p = &x;
    // This should fail: p lacks '+' permission
    stack i32 *r q = p + 1;
    ret *q;
}
